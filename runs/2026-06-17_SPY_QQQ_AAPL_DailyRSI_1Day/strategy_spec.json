{
  "strategy_name": "DailyRSIStrategy (stock-equivalent)",
  "source_module": "app/services/trading_engine.py",
  "asset_class": "stocks",
  "symbols": ["SPY", "QQQ", "AAPL"],
  "timeframe": "1Day",
  "feed": "sip",
  "adjustment": "split",
  "start": "2023-01-01",
  "end": "2025-12-31",
  "initial_cash": 100000,
  "indicators": {
    "rsi": {"variant": "wilder_smoothed", "period": 14, "field": "close"},
    "sma": {"variant": "simple", "period": 50, "field": "close"},
    "avg_volume_20": {"variant": "simple", "period": 20, "field": "volume"}
  },
  "entry": {
    "type": "all_of",
    "_matches_live_setting": "STRATEGY_REQUIRE_UPTREND_FILTER=false",
    "rules": [
      {"field": "rsi_14", "op": "<", "value": 35, "bound": "exclusive"}
    ],
    "rules_if_uptrend_filter_enabled": [
      {"field": "rsi_14", "op": "<", "value": 35, "bound": "exclusive"},
      {"field": "close", "op": ">", "value": "sma_50", "bound": "exclusive"},
      {"type": "any_of", "rules": [
        {"field": "close", "op": "<=", "value": "sma_50 * 1.05", "bound": "inclusive"},
        {"field": "volume", "op": ">", "value": "avg_volume_20", "bound": "exclusive"}
      ]}
    ]
  },
  "exit": {
    "type": "any_of",
    "rules": [
      {"field": "rsi_14", "op": ">", "value": 70, "bound": "exclusive"}
    ]
  },
  "signal_timing": "completed_bar_close",
  "fill_model": "next_open",
  "fill_friction_bps": {
    "spread_bps": 0,
    "slippage_bps": 5
  },
  "sizing": {
    "method": "equity_fraction_with_cap",
    "max_concurrent_positions": 3,
    "fraction_per_signal": "min(1/max_concurrent_positions, available_cash / proposed_notional)",
    "fractional_shares": false,
    "rounding": "floor"
  },
  "cash_handling": {
    "rebalance": "never",
    "interest_on_cash": false
  },
  "benchmark": {
    "name": "equal_weight_buy_and_hold",
    "components": ["SPY", "QQQ", "AAPL"],
    "rebalance": "never",
    "execution_assumptions": "same as strategy"
  },
  "calendar": {
    "session": "regular_hours",
    "include_extended_hours": false,
    "source": "alpaca_calendar"
  },
  "fees_modeled": false,
  "dividends_modeled": false,
  "corporate_actions": "split adjustment via feed",
  "warmup_bars": 65,
  "warmup_behavior": "no signals before rsi_14 and sma_50 are both defined",
  "excluded_layers_from_live_strategy": [
    "ATM call-option overlay (this backtest holds the underlying stock)",
    "HV-rank IV gate (skip BUY if HV rank > 50%)",
    "Earnings gate (skip BUY if earnings within 7 days)",
    "AI advisor LLM confidence filter (MIN_CONFIDENCE 0.65)",
    "Regime gate (VIX panic, SPY/QQQ trend)",
    "Risk gate (concentration / daily loss / drawdown)",
    "Option +60% profit target",
    "Option -30% stop loss",
    "Trailing stop arm-at-+20%-trail-15%",
    "Days-before-expiry exit (3d)",
    "Stage-2 ensemble confirm (Anthropic/OpenAI)"
  ]
}
