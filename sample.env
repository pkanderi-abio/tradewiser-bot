# TradeWiser Bot — Production Configuration Template
# Copy to .env and fill in your credentials before starting the service.

# ============================================================
# ALPACA API CREDENTIALS (REQUIRED)
# ============================================================
# Get keys at https://alpaca.markets/ (paper keys are free)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Paper trading (safe, no real money):
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Live trading (uncomment when ready):
# ALPACA_BASE_URL=https://api.alpaca.markets

# ============================================================
# LLM PROVIDER — choose ONE, leave the rest blank
# Priority order: OpenAI → Anthropic → Groq → Ollama
# ============================================================

# Groq (RECOMMENDED — free, 14,400 req/day, fastest)
# Get key at https://console.groq.com/ — no credit card needed
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (best quality, paid)
# Get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic Claude (excellent quality, paid)
# Get key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229

# Ollama — local, free, no key needed
# Install: https://ollama.ai  then: ollama pull llama3.2
OLLAMA_ENABLED=false
OLLAMA_MODEL=llama3.2
OLLAMA_URL=http://localhost:11434/v1

# ============================================================
# BOT API KEY (REQUIRED)
# ============================================================
# Protects all /trades, /quotes, and /watchlist endpoints.
# Set to any strong random string (e.g. openssl rand -hex 32).
# The service will NOT start if this is left blank.
BOT_API_KEY=change_me_to_a_strong_random_secret

# ============================================================
# AI TRADING CONFIGURATION
# ============================================================
AI_MIN_CONFIDENCE=0.65
AI_DECISION_CACHE_TTL=3600
AI_NEWS_CACHE_TTL=300
AI_SENTIMENT_ENABLED=true
AI_NEWS_ENABLED=true
AI_MARKET_INTELLIGENCE_ENABLED=true

# ============================================================
# TRADING CONFIGURATION
# ============================================================
TRADING_MAX_POSITION_SIZE=1000
TRADING_STOP_LOSS_PERCENT=2.0
TRADING_TAKE_PROFIT_PERCENT=5.0
TRADING_MIN_CONFIDENCE=0.60

# ============================================================
# SCHEDULER (autonomous trading loop)
# ============================================================
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=60
SCHEDULER_MARKET_OPEN_DELAY=300
SCHEDULER_MARKET_CLOSE_BUFFER=900

# ============================================================
# MISC
# ============================================================
POLL_INTERVAL=5
LOG_LEVEL=INFO
LOG_FILE=tradewiser.log
