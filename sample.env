# TradeWiser Bot - Production Configuration
# Copy this file to .env and update with your production credentials

# Alpaca API Credentials (REQUIRED)
# Get these from https://alpaca.markets/
ALPACA_API_KEY=your_production_api_key_here
ALPACA_SECRET_KEY=your_production_secret_key_here

# Use LIVE trading for production (remove for paper trading)
ALPACA_BASE_URL=https://api.alpaca.markets

# Trading Configuration
POLL_INTERVAL=5

# Legacy Webull settings (not used - kept for compatibility)
WEBULL_EMAIL=
WEBULL_PASSWORD=
WEBULL_DEVICE_NAME=TradeWiserBot